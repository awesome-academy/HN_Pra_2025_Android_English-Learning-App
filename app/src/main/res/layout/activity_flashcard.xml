<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/flashcard_background"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Modern Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/flashcard_surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp"
        android:paddingTop="24dp">

        <!-- Modern Back Button -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_audio_button_modern"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Go back to lesson"
                app:tint="@color/white"
                android:scaleType="centerInside" />

        </FrameLayout>

        <!-- Modern Title -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_bold"
            android:text="Flashcards"
            android:textColor="@color/flashcard_text_primary"
            android:textSize="24sp"
            android:letterSpacing="0.02" />

        <!-- Modern Position Indicator -->
        <TextView
            android:id="@+id/text_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_part_of_speech_modern"
            android:fontFamily="@font/nunito_bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:contentDescription="Current flashcard position"
            android:elevation="4dp"
            android:letterSpacing="0.1"
            tools:text="1 / 10" />

    </LinearLayout>

    <!-- Modern ViewPager2 for Flashcards -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_flashcards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp"
        android:paddingVertical="16dp"
        android:clipToPadding="false"
        android:clipChildren="false" />

    <!-- Modern Bottom Navigation Hints -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/flashcard_surface"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="20dp"
        android:paddingBottom="24dp"/>

</LinearLayout>
