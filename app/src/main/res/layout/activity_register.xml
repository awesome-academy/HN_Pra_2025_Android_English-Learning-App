<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:padding="@dimen/dp_24"
    tools:context=".screen.register.RegisterActivity">

    <!-- Welcome Title -->
    <TextView
        android:id="@+id/tv_welcome_title"
        style="@style/TextBold.24sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_48"
        android:text="@string/welcome_register_title"
        android:textColor="@color/text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Google Sign Up Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_google_sign_up"
        style="@style/TextSemiBold.16sp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:backgroundTint="@color/login_google_bg"
        android:paddingVertical="@dimen/dp_16"
        android:text="@string/google_sign_up_button"
        android:textColor="@color/text_primary"
        app:cornerRadius="@dimen/dp_12"
        app:icon="@drawable/ic_google_logo"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/dp_8"
        app:iconTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_welcome_title"
        app:strokeColor="@color/login_separator"
        app:strokeWidth="@dimen/dp_1" />

    <!-- Separator -->
    <LinearLayout
        android:id="@+id/layout_separator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_32"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_google_sign_up">

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_1"
            android:layout_weight="1"
            android:background="@color/login_separator" />

        <TextView
            style="@style/TextRegular.14sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dp_16"
            android:text="@string/or_separator"
            android:textColor="@color/login_text_hint" />

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_1"
            android:layout_weight="1"
            android:background="@color/login_separator" />
    </LinearLayout>

    <!-- Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_32"
        android:hint="@string/name_hint"
        app:boxCornerRadiusBottomEnd="@dimen/dp_12"
        app:boxCornerRadiusBottomStart="@dimen/dp_12"
        app:boxCornerRadiusTopEnd="@dimen/dp_12"
        app:boxCornerRadiusTopStart="@dimen/dp_12"
        app:boxStrokeColor="@color/login_primary"
        app:hintTextColor="@color/login_text_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_separator"
        app:startIconDrawable="@drawable/ic_user"
        app:startIconTint="@color/login_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            style="@style/TextRegular.16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName"
            android:paddingVertical="@dimen/dp_16"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Email Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_email"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:hint="@string/email_hint"
        app:boxCornerRadiusBottomEnd="@dimen/dp_12"
        app:boxCornerRadiusBottomStart="@dimen/dp_12"
        app:boxCornerRadiusTopEnd="@dimen/dp_12"
        app:boxCornerRadiusTopStart="@dimen/dp_12"
        app:boxStrokeColor="@color/login_primary"
        app:hintTextColor="@color/login_text_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/til_name"
        app:startIconDrawable="@drawable/ic_email"
        app:startIconTint="@color/login_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_email"
            style="@style/TextRegular.16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:paddingVertical="@dimen/dp_16"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_password"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:hint="@string/password_hint"
        app:boxCornerRadiusBottomEnd="@dimen/dp_12"
        app:boxCornerRadiusBottomStart="@dimen/dp_12"
        app:boxCornerRadiusTopEnd="@dimen/dp_12"
        app:boxCornerRadiusTopStart="@dimen/dp_12"
        app:boxStrokeColor="@color/login_primary"
        app:endIconMode="password_toggle"
        app:hintTextColor="@color/login_text_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/til_email"
        app:startIconDrawable="@drawable/ic_lock"
        app:startIconTint="@color/login_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_password"
            style="@style/TextRegular.16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:paddingVertical="@dimen/dp_16"
            android:textColor="@color/text_primary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Register Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_register"
        style="@style/TextSemiBold.16sp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_32"
        android:backgroundTint="@color/login_primary"
        android:paddingVertical="@dimen/dp_16"
        android:text="@string/create_account_button"
        android:textColor="@color/white"
        app:cornerRadius="@dimen/dp_12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_password" />

    <!-- Terms and Conditions Text -->
    <TextView
        android:id="@+id/tv_terms"
        style="@style/TextRegular.12sp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_24"
        android:gravity="center"
        android:text="@string/terms_and_conditions"
        android:textColor="@color/login_text_hint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_register" />

    <!-- Login Link -->
    <LinearLayout
        android:id="@+id/layout_login_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_32"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            style="@style/TextRegular.14sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/already_have_account"
            android:textColor="@color/login_text_hint" />

        <TextView
            android:id="@+id/tv_login_link"
            style="@style/TextSemiBold.14sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_4"
            android:text="@string/login_link"
            android:textColor="@color/login_primary" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
