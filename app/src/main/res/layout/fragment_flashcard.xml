<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/dp_8"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/dp_20"
    app:cardElevation="@dimen/dp_8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/dp_32">

            <!-- Word Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/dp_32">

                <!-- Word Icon -->
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/dp_80"
                    android:layout_height="@dimen/dp_80"
                    android:layout_marginBottom="@dimen/dp_20"
                    app:cardBackgroundColor="@color/main_blue"
                    app:cardCornerRadius="@dimen/dp_40"
                    app:cardElevation="@dimen/dp_0">

                    <TextView
                        android:id="@+id/text_word_initial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_32"
                        android:fontFamily="@font/nunito_bold"
                        android:contentDescription="Word initial letter"
                        tools:text="S" />

                </androidx.cardview.widget.CardView>

                <!-- Word Name -->
                <TextView
                    android:id="@+id/text_word_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_12"
                    android:fontFamily="@font/nunito_bold"
                    android:gravity="center"
                    android:textColor="@color/lesson_title_text"
                    android:textSize="@dimen/sp_36"
                    android:contentDescription="English word"
                    tools:text="School" />

                <!-- Phonetic and Audio -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Phonetic -->
                    <TextView
                        android:id="@+id/text_phonetic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/dp_12"
                        android:fontFamily="serif"
                        android:textColor="@color/lesson_subtitle_text"
                        android:textSize="@dimen/sp_18"
                        android:contentDescription="Phonetic transcription"
                        tools:text="/skuːl/" />

                    <!-- Audio Button -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="@dimen/dp_48"
                        android:layout_height="@dimen/dp_48"
                        app:cardBackgroundColor="@color/secondary_orange"
                        app:cardCornerRadius="@dimen/dp_24"
                        app:cardElevation="@dimen/dp_4">

                        <ImageView
                            android:id="@+id/btn_audio"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="@dimen/dp_12"
                            android:src="@drawable/ic_volume"
                            android:contentDescription="Play pronunciation audio"
                            app:tint="@color/white" />

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- Part of Speech -->
            <TextView
                android:id="@+id/text_part_of_speech"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/dp_24"
                android:background="@drawable/word_count_background"
                android:fontFamily="@font/nunito_bold"
                android:paddingHorizontal="@dimen/dp_16"
                android:paddingVertical="@dimen/dp_8"
                android:textColor="@color/main_blue"
                android:textSize="@dimen/sp_14"
                android:visibility="gone"
                tools:text="noun"
                tools:visibility="visible" />

            <!-- Definition Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/dp_24"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_12"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Definition"
                    android:textColor="@color/main_blue"
                    android:textSize="@dimen/sp_16" />

                <TextView
                    android:id="@+id/text_definition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_medium"
                    android:lineSpacingExtra="@dimen/dp_4"
                    android:textColor="@color/lesson_title_text"
                    android:textSize="@dimen/sp_18"
                    tools:text="An institution for educating children and young people" />

            </LinearLayout>

            <!-- Example Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/example_background"
                android:orientation="vertical"
                android:padding="@dimen/dp_20">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_12"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Example"
                    android:textColor="@color/secondary_orange"
                    android:textSize="@dimen/sp_16" />

                <TextView
                    android:id="@+id/text_example"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_regular"
                    android:fontStyle="italic"
                    android:lineSpacingExtra="@dimen/dp_4"
                    android:textColor="@color/lesson_subtitle_text"
                    android:textSize="@dimen/sp_17"
                    tools:text="I go to school every day to learn new things." />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.cardview.widget.CardView>
