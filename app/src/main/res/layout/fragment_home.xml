<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".screen.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_text"
                    android:textSize="28sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/nunito_bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle_text"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/nunito_regular" />

            </LinearLayout>

            <ImageView
                android:id="@+id/iv_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_search"
                android:background="@drawable/category_card_background"
                android:backgroundTint="@color/main_blue"
                android:padding="12dp"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <!-- Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/lesson_card_background"
            android:padding="24dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_learning_time_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/learning_time_label"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/nunito_regular"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btn_lets_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lets_start_button"
                    android:backgroundTint="@color/main_blue"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/nunito_semibold"
                    android:textSize="14sp"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    app:cornerRadius="8dp" />

            </LinearLayout>

            <RelativeLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progress_ring"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:progress="65"
                    android:progressDrawable="@drawable/progress_ring"
                    style="?android:attr/progressBarStyleHorizontal" />

                <TextView
                    android:id="@+id/tv_learning_time_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/learning_time_value"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/nunito_bold"
                    android:layout_centerInParent="true" />

            </RelativeLayout>

        </LinearLayout>

        <!-- Courses Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/courses_section_title"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/nunito_bold" />

            <LinearLayout
                android:id="@+id/ll_view_all_courses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_courses"
                    android:textSize="14sp"
                    android:textColor="@color/main_blue"
                    android:fontFamily="@font/nunito_medium"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right" />

            </LinearLayout>

        </LinearLayout>

        <!-- Course Categories Horizontal ScrollView -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingEnd="24dp">

                <!-- Travel Category -->
                <LinearLayout
                    android:id="@+id/ll_travel_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/travel_image"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_travel"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_gravity="center_horizontal" />

                </LinearLayout>

                <!-- Practice Category -->
                <LinearLayout
                    android:id="@+id/ll_practice_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/practice_image"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_practice"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_gravity="center_horizontal" />

                </LinearLayout>

                <!-- Business Category -->
                <LinearLayout
                    android:id="@+id/ll_business_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/business_image"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_business"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_gravity="center_horizontal" />

                </LinearLayout>

                <!-- Academic Category -->
                <LinearLayout
                    android:id="@+id/ll_academic_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/academic_image"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_academic"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/nunito_medium"
                        android:layout_gravity="center_horizontal" />

                </LinearLayout>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Recent Learning Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/recent_learning_title"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/nunito_bold" />

            <LinearLayout
                android:id="@+id/ll_view_all_recent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_recent"
                    android:textSize="14sp"
                    android:textColor="@color/main_blue"
                    android:fontFamily="@font/nunito_medium"
                    android:layout_marginEnd="4dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right" />

            </LinearLayout>

        </LinearLayout>

        <!-- Recent Learning Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Tourist Trip Card -->
            <LinearLayout
                android:id="@+id/ll_tourist_trip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/lesson_card_background"
                android:padding="12dp"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/tourist_trip_image"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tourist_trip"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/nunito_semibold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_book_small"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lesson: 3"
                            android:textSize="10sp"
                            android:textColor="@color/text_light"
                            android:fontFamily="@font/nunito_regular" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_star_small"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Advanced: 76"
                            android:textSize="10sp"
                            android:textColor="@color/text_light"
                            android:fontFamily="@font/nunito_regular" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Progress Bar -->
                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="60"
                    android:max="100"
                    android:progressTint="@color/secondary_orange"
                    android:progressBackgroundTint="@color/progress_background"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6/10"
                    android:textSize="10sp"
                    android:textColor="@color/secondary_orange"
                    android:fontFamily="@font/nunito_regular" />

            </LinearLayout>

            <!-- Hang Out Card -->
            <LinearLayout
                android:id="@+id/ll_hang_out_friends"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/lesson_card_background"
                android:padding="12dp"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/hang_out_image"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hang_out_friends"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/nunito_semibold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_book_small"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lesson: 3"
                            android:textSize="10sp"
                            android:textColor="@color/text_light"
                            android:fontFamily="@font/nunito_regular" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_star_small"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Advanced: 45"
                            android:textSize="10sp"
                            android:textColor="@color/text_light"
                            android:fontFamily="@font/nunito_regular" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Progress Bar -->
                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:progress="30"
                    android:max="100"
                    android:progressTint="@color/secondary_orange"
                    android:progressBackgroundTint="@color/progress_background"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3/10"
                    android:textSize="10sp"
                    android:textColor="@color/secondary_orange"
                    android:fontFamily="@font/nunito_regular" />

            </LinearLayout>

        </LinearLayout>

        <!-- Suggested Courses Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/suggested_courses_title"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/nunito_bold" />

            <ImageView
                android:id="@+id/iv_refresh_suggestions"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_refresh"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <!-- Suggested Course Card -->
        <LinearLayout
            android:id="@+id/ll_suggested_course"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/lesson_card_background"
            android:padding="16dp">

            <!-- Course Image with Check Icon -->
            <RelativeLayout
                android:layout_width="120dp"
                android:layout_height="80dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/office_conversation_image"
                    android:scaleType="centerCrop" />

                <!-- Check Circle Icon -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/check_circle_background"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"
                    android:layout_margin="8dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check_circle"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"
                    android:layout_margin="12dp" />

            </RelativeLayout>

            <!-- Course Content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/office_conversation_title"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/nunito_semibold"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/office_conversation_subtitle"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="@font/nunito_regular" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
